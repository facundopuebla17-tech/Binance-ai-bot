# ─────────────────────────────────────────────
#  BINANCE AI TRADING BOT — Variables de entorno
#  Copiá este archivo como .env y completalo
#  NUNCA subas el .env a GitHub
# ─────────────────────────────────────────────

# Binance API (obtené en https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# Para testnet usá: https://testnet.binance.vision
BINANCE_BASE_URL=https://api.binance.com

# Anthropic API (obtené en https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Token secreto para autenticar requests al backend (inventá uno largo y random)
BOT_SECRET_TOKEN=tu_token_secreto_muy_largo_aqui

# Servidor
PORT=3000

# Límites de riesgo
MAX_ORDER_USDT=500
DAILY_LOSS_LIMIT_USDT=200
ALLOWED_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
